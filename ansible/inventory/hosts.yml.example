# SIB Fleet Inventory
# Copy this to hosts.yml and customize for your environment

all:
  vars:
    # Central SIB server configuration
    sib_server: "192.168.1.100"  # REQUIRED: Change to your SIB server IP
    
    # Default SSH settings
    ansible_user: root
    ansible_ssh_private_key_file: ~/.ssh/id_rsa
    
  children:
    # Fleet hosts to monitor
    fleet:
      vars:
        # Fleet hosts need sudo for installing/managing services
        ansible_become: true
      hosts:
        # Example hosts - customize for your environment
        webserver:
          ansible_host: 192.168.1.10
          host_labels:
            role: web
            environment: production
        
        database:
          ansible_host: 192.168.1.11
          host_labels:
            role: database
            environment: production
        
        # Add more hosts as needed
        # appserver:
        #   ansible_host: 192.168.1.12
        #   host_labels:
        #     role: app
        #     environment: staging

      # vars:
        # Fleet-specific variables (override group_vars/all.yml)
        # falco_priority: notice
        # deployment_strategy: docker
